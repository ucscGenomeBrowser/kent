track ncOrfs
superTrack on
shortLabel non-canonical ORFs
longLabel Non-canonical Open Reading Frames
group genes

    track utrAnnotUorfs
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/utrAnnotUorfs.bb
    shortLabel UTRannotator uORFs
    longLabel ncORFs: Upstream Open Reading Frames (uORFs) from UTRannotator
    type bigBed 9 +
    itemRgb on
    mouseOverField uorfType
    visibility pack

    track gencNcOrfs
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/gencNcOrf/Ribo-seq_ORFs.bb
    shortLabel Gencode non-canonical ORFs Phase I
    longLabel ncORFs: Gencode Phase I non-canonical ORFs supported by Ribo-seq data
    type bigGenePred
    itemRgb on
    mouseOverField transcripts ${all_transcript_ids}, genes ${all_gene_ids}, replicated ${replicated}, studies ${ref_studies}
    html gencNcOrfs
    visibility pack

    track gencNcOrfsPrimary
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/gencNcOrf/Ribo-seq_ORFs.primary.bb
    shortLabel Gencode non-canonical ORFs Phase II primary
    longLabel ncORFs: Gencode Phase II non-canonical ORFs - primary
    type bigBed 12 +
    itemRgb on
    #mouseOverField transcripts ${all_transcript_ids}, genes ${all_gene_ids}, replicated ${replicated}, studies ${ref_studies}
    html gencNcOrfs
    visibility pack

    track gencNcOrfsComprehensive
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/gencNcOrf/Ribo-seq_ORFs.comprehensive.bb
    shortLabel Gencode non-canonical ORFs Phase II comprehensive
    longLabel ncORFs: Gencode Phase II non-canonical ORFs - comprehensive
    type bigBed 12 +
    itemRgb on
    #mouseOverField transcripts ${all_transcript_ids}, genes ${all_gene_ids}, replicated ${replicated}, studies ${ref_studies}
    html gencNcOrfs
    visibility pack

    track metamorf
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/metamorf/MetamORF.bb
    shortLabel MetamORF
    longLabel ncORFs: MetamORF - meta-database of non-canonical ORFs
    type bigBed 12 +
    itemRgb on
    visibility pack

    track nuorfdb
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/nuorfdb/nuorfdb.bb
    shortLabel nuORFdb
    longLabel ncORFs: nuORFdb - non-canonical ORFs from nuORFdb v1.2
    type bigGenePred
    itemRgb on
    mouseOverField plotType
    visibility pack

    track openprot
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/openprot/openprot.bb
    shortLabel OpenProt
    longLabel ncORFs: OpenProt - alternative and reference proteins v2.2
    type bigGenePred
    itemRgb on
    mouseOverField localization
    filterByRange.msScore on
    filterValues.type AltProt|AltProt,RefProt|RefProt,Isoform|Isoform
    filterValues.localization 5'UTR|5'UTR,3'UTR|3'UTR,CDS|CDS,ncRNA|ncRNA,multiple|multiple
    visibility pack

    track openprotMs
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/openprot/openprot.ms2.bb
    shortLabel OpenProt (MS>=2)
    longLabel ncORFs: OpenProt - proteins with at least 2 MS peptides v2.2
    type bigGenePred
    itemRgb on
    mouseOverField localization
    filterByRange.msScore on
    filterValues.type AltProt|AltProt,RefProt|RefProt,Isoform|Isoform
    filterValues.localization 5'UTR|5'UTR,3'UTR|3'UTR,CDS|CDS,ncRNA|ncRNA,multiple|multiple
    html openprot
    visibility hide
