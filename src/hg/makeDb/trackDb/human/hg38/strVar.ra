track strVar
shortLabel Tandem Repeat Variation
longLabel Tandem Repeat Variation
group varRep
superTrack on
visibility hide

    track webstr
    shortLabel WebSTR
    longLabel WebSTR Short Tandem Repeat Loci (EnsembleTR Panel, 1000 Genomes)
    type bigBed 9 +
    itemRgb on
    bigDataUrl /gbdb/hg38/strVar/webstr.bb
    visibility dense
    superTrack strVar dense
    url https://webstr.ucsd.edu/locus?repeat_id=$$&genome=hg38
    urlLabel WebSTR locus page
    searchIndex name
    mouseOver <b>Repeat motif:</b> $motif ($period bp) <br> <b>Number of copies:</b> $numCopies <br> <b>Population sample counts:</b> <br> $afrN (AFR), $amrN (AMR), $easN (EAS), $eurN (EUR), $sasN (SAS)

    track strchive
    shortLabel STRchive
    longLabel STRchive Disease-Associated Short Tandem Repeat Loci
    type bigBed 9 +
    itemRgb on
    bigDataUrl /gbdb/hg38/strVar/strchive.bb
    visibility pack
    superTrack strVar pack
    url https://strchive.org/loci/$$
    urlLabel STRchive locus page
    searchIndex name
    mouseOver <b>Gene:</b> $gene <br> <b>Motif:</b> $referenceMotif <br> <b>Minimum pathogenic repeat:</b> $pathogenicMin <br> <b>Mode of inheritance:</b> $inheritance <br> <b>Associated disease(s):</b> $disease
    dataVersion  /gbdb/hg38/strVar/strchive.version.txt

    track trexplorer
    shortLabel TRExplorer
    longLabel TRExplorer V2 Tandem Repeat Catalog
    type bigBed 9 +
    itemRgb on
    bigDataUrl /gbdb/hg38/strVar/trexplorer.bb
    visibility dense
    superTrack strVar dense
    urls locusId="https://trexplorer.broadinstitute.org/index.html?#showRs=1&q=$$"
    urlLabel TRExplorer locus page
    searchIndex name
    mouseOver <b>Gene:</b> $geneName ($geneRegion) <br> <b>Reference Motif:</b> $referenceMotif ($motifSize bp) <br> <b>Number of repeat copies:</b> $numRepeats repeats <br> <b>Purity:</b> $repeatPurity <br> <b>Number of called alleles:</b><br> $tenKNumAlleles (TenK10K), $hprcNumAlleles (HRPC256), $aouNumAlleles (AoU1027) <br><b>Source:</b> $source
    #mouseOver $referenceMotif ($motifSize bp), $numRepeats repeats, purity $repeatPurity, $geneName $geneRegion, $source
    detailsJs detailsHistogram.js
    detailsJsFields tenKAlleleSizes,tenKAlleleCounts,hprcAlleleSizes,hprcAlleleCounts
    detailsJsArgs {"histograms":[{"binsField":"tenKAlleleSizes","valuesField":"tenKAlleleCounts","title":"TenK10K Allele Distribution"},{"binsField":"hprcAlleleSizes","valuesField":"hprcAlleleCounts","title":"HPRC256 Allele Distribution"}]}
