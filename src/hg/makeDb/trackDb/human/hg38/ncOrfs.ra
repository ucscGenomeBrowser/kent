track ncOrfs
superTrack on
shortLabel non-canonical ORFs
longLabel Non-canonical Open Reading Frames
group genes

    track utrAnnotUorfs
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/utrAnnotUorfs.kozak.bb
    shortLabel UTRannotator uORFs
    longLabel ncORFs: Upstream Open Reading Frames (uORFs) from UTRannotator
    type bigGenePred
    itemRgb on
    baseColorUseCds given
    baseColorDefault genomicCodons
    mouseOver <b>$name</b> uORF ($uorfType)<br> <b>Start codon</b>: $startCodon<br> <b>Kozak</b>: $kozakStrength (TE $kozakTE)
    filterValues.startCodon ATG,CTG,GTG,TTG,ACG,other,none
    filterType.startCodon multipleListOr
    filterValues.kozakStrength Strong,Moderate,Weak,non-ATG,None
    filterType.kozakStrength multipleListOr
    filterByRange.kozakTE on
    filter.kozakTE 0:1.5
    filterLimits.kozakTE 0:1.5
    filterValues.uorfType 5'UTR uORF,5'UTR uORF extending into 3'UTR
    filterType.uorfType multipleListOr
    visibility pack

    track gencNcOrfs
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/gencNcOrf/Ribo-seq_ORFs.kozak.bb
    shortLabel Gencode non-canonical ORFs Phase I
    longLabel ncORFs: Gencode Phase I non-canonical ORFs supported by Ribo-seq data
    type bigGenePred
    itemRgb on
    baseColorUseCds given
    baseColorDefault genomicCodons
    mouseOver <b>$name</b> in <b>$geneName2</b> ($geneType)<br> <b>Start codon</b>: $startCodon<br> <b>Kozak</b>: $kozakStrength (TE $kozakTE)<br> <b>Replicated</b>: $replicated<br> <b>Studies</b>: $ref_studies
    filterValues.startCodon ATG,CTG,GTG,TTG,ACG,other,none
    filterType.startCodon multipleListOr
    filterValues.kozakStrength Strong,Moderate,Weak,non-ATG,None
    filterType.kozakStrength multipleListOr
    filterByRange.kozakTE on
    filter.kozakTE 0:1.5
    filterLimits.kozakTE 0:1.5
    filterValues.replicated yes,no
    filterType.replicated multipleListOr
    html gencNcOrfs
    visibility pack

    track gencNcOrfsPrimary
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/gencNcOrf/Ribo-seq_ORFs.primary.kozak.bb
    shortLabel Gencode non-canonical ORFs Phase II primary
    longLabel ncORFs: Gencode Phase II non-canonical ORFs - primary
    type bigGenePred
    itemRgb on
    baseColorUseCds given
    baseColorDefault genomicCodons
    mouseOver <b>$name</b> in <b>$geneName2</b> ($geneType)<br> <b>Start codon</b>: $startCodon<br> <b>Kozak</b>: $kozakStrength (TE $kozakTE)
    filterValues.startCodon ATG,CTG,GTG,TTG,ACG,other,none
    filterType.startCodon multipleListOr
    filterValues.kozakStrength Strong,Moderate,Weak,non-ATG,None
    filterType.kozakStrength multipleListOr
    filterByRange.kozakTE on
    filter.kozakTE 0:1.5
    filterLimits.kozakTE 0:1.5
    html gencNcOrfs
    visibility pack

    track gencNcOrfsComprehensive
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/gencNcOrf/Ribo-seq_ORFs.comprehensive.kozak.bb
    shortLabel Gencode non-canonical ORFs Phase II comprehensive
    longLabel ncORFs: Gencode Phase II non-canonical ORFs - comprehensive
    type bigGenePred
    itemRgb on
    baseColorUseCds given
    baseColorDefault genomicCodons
    mouseOver <b>$name</b> in <b>$geneName2</b> ($geneType)<br> <b>Start codon</b>: $startCodon<br> <b>Kozak</b>: $kozakStrength (TE $kozakTE)
    filterValues.startCodon ATG,CTG,GTG,TTG,ACG,other,none
    filterType.startCodon multipleListOr
    filterValues.kozakStrength Strong,Moderate,Weak,non-ATG,None
    filterType.kozakStrength multipleListOr
    filterByRange.kozakTE on
    filter.kozakTE 0:1.5
    filterLimits.kozakTE 0:1.5
    html gencNcOrfs
    visibility pack

    track metamorf
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/metamorf/MetamORF.kozak.bb
    shortLabel MetamORF
    longLabel ncORFs: MetamORF - meta-database of non-canonical ORFs
    type bigGenePred
    itemRgb on
    baseColorUseCds given
    baseColorDefault genomicCodons
    mouseOver <b>$name</b> ($type)<br> <b>Start codon</b>: $startCodon<br> <b>Kozak</b>: $kozakStrength (TE $kozakTE)<br> <b>Transcripts</b>: $transcripts<br> <b>Cell types</b>: $cell_types
    filterValues.startCodon ATG,CTG,GTG,TTG,ACG,other,none
    filterType.startCodon multipleListOr
    filterValues.kozakStrength Strong,Moderate,Weak,non-ATG,None
    filterType.kozakStrength multipleListOr
    filterByRange.kozakTE on
    filter.kozakTE 0:1.5
    filterLimits.kozakTE 0:1.5
    visibility pack

    track nuorfdb
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/nuorfdb/nuorfdb.kozak.bb
    shortLabel nuORFdb
    longLabel ncORFs: nuORFdb - non-canonical ORFs from nuORFdb v1.2
    type bigGenePred
    itemRgb on
    baseColorUseCds given
    baseColorDefault genomicCodons
    mouseOver <b>$name</b> in <b>$geneName2</b> ($geneType)<br> <b>Start codon</b>: $startCodon<br> <b>Kozak</b>: $kozakStrength (TE $kozakTE)<br> <b>Predictor</b>: $predictorType<br> <b>Plot type</b>: $plotType
    filterValues.startCodon ATG,CTG,GTG,TTG,ACG,other,none
    filterType.startCodon multipleListOr
    filterValues.kozakStrength Strong,Moderate,Weak,non-ATG,None
    filterType.kozakStrength multipleListOr
    filterByRange.kozakTE on
    filter.kozakTE 0:1.5
    filterLimits.kozakTE 0:1.5
    visibility pack

    track openprot
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/openprot/openprot.kozak.bb
    shortLabel OpenProt
    longLabel ncORFs: OpenProt - alternative and reference proteins v2.2
    type bigGenePred
    itemRgb on
    baseColorUseCds given
    baseColorDefault genomicCodons
    mouseOver <b>$name</b> in <b>$geneName2</b> ($type, $localization)<br> <b>Start codon</b>: $startCodon<br> <b>Kozak</b>: $kozakStrength (TE $kozakTE)<br> <b>MS score</b>: $msScore <b>TE score</b>: $teScore <b>Domains</b>: $domains
    filterValues.startCodon ATG,CTG,GTG,TTG,ACG,other,none
    filterType.startCodon multipleListOr
    filterValues.kozakStrength Strong,Moderate,Weak,non-ATG,None
    filterType.kozakStrength multipleListOr
    filterByRange.kozakTE on
    filter.kozakTE 0:1.5
    filterLimits.kozakTE 0:1.5
    filterByRange.msScore on
    filterValues.type AltProt|AltProt,RefProt|RefProt,Isoform|Isoform
    filterValues.localization 5'UTR|5'UTR,3'UTR|3'UTR,CDS|CDS,ncRNA|ncRNA,multiple|multiple
    visibility pack

    track openprotMs
    parent ncOrfs
    bigDataUrl /gbdb/hg38/ncOrfs/openprot/openprot.ms2.kozak.bb
    shortLabel OpenProt (MS>=2)
    longLabel ncORFs: OpenProt - proteins with at least 2 MS peptides v2.2
    type bigGenePred
    itemRgb on
    baseColorUseCds given
    baseColorDefault genomicCodons
    mouseOver <b>$name</b> in <b>$geneName2</b> ($type, $localization)<br> <b>Start codon</b>: $startCodon<br> <b>Kozak</b>: $kozakStrength (TE $kozakTE)<br> <b>MS score</b>: $msScore <b>TE score</b>: $teScore <b>Domains</b>: $domains
    filterValues.startCodon ATG,CTG,GTG,TTG,ACG,other,none
    filterType.startCodon multipleListOr
    filterValues.kozakStrength Strong,Moderate,Weak,non-ATG,None
    filterType.kozakStrength multipleListOr
    filterByRange.kozakTE on
    filter.kozakTE 0:1.5
    filterLimits.kozakTE 0:1.5
    filterByRange.msScore on
    filterValues.type AltProt|AltProt,RefProt|RefProt,Isoform|Isoform
    filterValues.localization 5'UTR|5'UTR,3'UTR|3'UTR,CDS|CDS,ncRNA|ncRNA,multiple|multiple
    html openprot
    visibility hide
